# SkyForge Ubuntu launcher configuration.
# This file is sourced by Bash. Use KEY=value syntax and do not add untrusted commands.

# auto: use ROS mode when /opt/ros/noetic exists; demo otherwise.
SKYFORGE_MODE=auto
SKYFORGE_HOST=127.0.0.1
SKYFORGE_PORT=3000

# ROS1 Noetic topics.
SKYFORGE_ROS_NODE=skyforge_gateway
SKYFORGE_FIX_TOPIC=/fix
SKYFORGE_ODOM_TOPIC=/odom
SKYFORGE_REGION_TOPIC=/selected_region

# Complete these before starting a real localization launch.
SKYFORGE_LAUNCH_PACKAGE=
SKYFORGE_LAUNCH_FILE=
SKYFORGE_LAUNCH_ARGS=

# Optional additional catkin workspace setup script.
# SKYFORGE_EXTRA_SETUP=/home/your-user/catkin_ws/devel/setup.bash

# Optional explicit executable paths.
# SKYFORGE_PYTHON=/absolute/path/to/project/.venv/bin/python
# SKYFORGE_BROWSER=chromium-browser

# Keep disabled for the typed skyforge_msgs/RegionCommand path.
SKYFORGE_ALLOW_STRING_FALLBACK=0
SKYFORGE_ALLOW_REMOTE_AGENT=0
